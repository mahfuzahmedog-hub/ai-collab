# OpenCode / AI Collab Environment Variables
# Convex deployment URL (from your Convex dashboard)
VITE_CONVEX_URL=https://lovely-lion-156.convex.cloud

# OmniRoute LLM Gateway Configuration
# Set OMNIROUTE_API_KEY to enable real LLM responses
# Get your API key from https://omniroute.ai or run OmniRoute locally
# Default local OmniRoute runs at http://localhost:20128/v1 with key "sk_omniroute"
OMNIROUTE_API_KEY=sk_omniroute
OMNIROUTE_BASE_URL=http://localhost:20128/v1
OMNIROUTE_DEFAULT_MODEL=auto

# Optional: Alternative LLM providers (used as fallback)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=

# Vly Integration (pre-existing)
VITE_VLY_APP_ID=
VITE_VLY_API_KEY=